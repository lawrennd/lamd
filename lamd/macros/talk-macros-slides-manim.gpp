\ifndef{talkMacrosSlidesManim}
\define{talkMacrosSlidesManim}

\define{\newslide{title}{commands}}{
        self.next_slide()
        self.play(FadeIn(lamd_text(r"""\title""")))}

\define{\subsection{title}}{
        self.next_slide()
        self.play(FadeIn(lamd_text(r"""\title""")))}

\define{\subsubsection{title}}{
        self.next_slide()
        self.play(FadeIn(lamd_text(r"""\title""")))}

\define{\section{title}}{
        self.next_slide()
        self.play(FadeIn(lamd_text(r"""\title""")))}

\endif
